# Base mainnet（8453）— BaseTreasury；勿与下方 CoNET 的 ConetTreasury 地址互换
BASE_TREASURY_ADDRESS=0x5c64a8b0935DA72d60933bBD8cD10579E1C40c58
# 优先使用 Beamio Base RPC wss；vote 与 /base-rpc 转发内部转为 https
BASE_RPC=wss://base-rpc.conet.network/ws
# Base RPC HTTP：当 BASE_RPC 未设置时使用
BASE_RPC_HTTP=https://base-rpc.conet.network

# CoNET mainnet（224422）— ConetTreasury；勿与上方 Base 的 BaseTreasury 混淆
CONET_TREASURY_ADDRESS=0x6dC686831A497c2a9d0a2ff5A000E3Bb40a2E795
CONET_RPC=https://publicrpc.conet.network
