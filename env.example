# Base mainnet
BASE_TREASURY_ADDRESS=0x5c64a8b0935DA72d60933bBD8cD10579E1C40c58
BASE_RPC=wss://base-rpc.conet.network/ws
# Base RPC HTTP：vote 轮询与 /base-rpc 转发均用此 URL。使用 1rpc.io 等仅 HTTP 的 RPC 时必须设置
# 未设置时 vote 会将 BASE_RPC 的 wss 转为 https
BASE_RPC_HTTP=https://1rpc.io/base

# CoNET mainnet
CONET_TREASURY_ADDRESS=0xA7fb50fE8e09E17E74081014d49f4E80729cCA48
CONET_RPC=https://mainnet-rpc.conet.network
