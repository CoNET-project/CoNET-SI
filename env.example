# 统一国库 ConetTreasury（CREATE2 跨链同址 0xa311…3B30）
# Base(8453)：已部署；监听 BUnitPurchased、USDC 入金
BASE_TREASURY_ADDRESS=0xa311c8fBE7CafC611603Ee925465A62493B73B30
# 优先使用 Beamio Base RPC wss；vote 与 /base-rpc 转发内部转为 https
BASE_RPC=wss://base-rpc.conet.network/ws
# Base RPC HTTP：当 BASE_RPC 未设置时使用
BASE_RPC_HTTP=https://base-rpc.conet.network

# CoNET(224422)：与 Base 同 CREATE2 地址；须 deployConetTreasuryCreate2 --network conet 部署后才有 code
CONET_TREASURY_ADDRESS=0xa311c8fBE7CafC611603Ee925465A62493B73B30
CONET_RPC=https://publicrpc.conet.network

